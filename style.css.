*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Noto Sans KR',sans-serif;
}

body{
    height:100vh;
    overflow:hidden;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#ffd6e8,#ffeef6,#ffd9ec);
    background-size:300% 300%;
    animation:bgMove 10s ease infinite;
}

.container{
    width:90%;
    max-width:520px;
    padding:35px;
    text-align:center;

    background:rgba(255,255,255,.82);
    backdrop-filter:blur(18px);

    border-radius:30px;

    box-shadow:0 20px 60px rgba(255,105,180,.3);

    position:relative;
    z-index:5;

    animation:fadeUp 1s;
}

.profile{

    width:220px;
    height:220px;

    border-radius:50%;

    object-fit:cover;

    border:6px solid white;

    margin-bottom:20px;

    animation:
    floating 3s ease-in-out infinite,
    glow 2s infinite;

}

h1{

    color:#ff2f7a;
    font-size:40px;

}

h2{

    margin:15px 0;

    color:#ff5f99;

}

.letter{

    color:#666;

    line-height:2;

    min-height:240px;

    margin-bottom:25px;

}

.buttons{

    width:330px;

    height:180px;

    margin:auto;

    position:relative;

}

button{

    border:none;

    border-radius:50px;

    padding:16px 35px;

    font-size:20px;

    cursor:pointer;

    transition:.3s;

}

#yesBtn{

    position:absolute;

    left:20px;

    top:60px;

    color:white;

    background:#ff4d94;

    box-shadow:0 0 20px hotpink;

}

#yesBtn:hover{

    transform:scale(1.08);

}

#noBtn{

    position:absolute;

    right:20px;

    top:60px;

    color:white;

    background:#888;

}

#teaseText{

    height:45px;

    color:#ff2f7a;

    font-weight:bold;

    margin-top:20px;

}

.hearts,
.petals{

    position:fixed;

    inset:0;

    pointer-events:none;

}

.heart,
.petal{

    position:absolute;

    animation:fall linear forwards;

}

#loveScreen{

    position:fixed;

    inset:0;

    background:linear-gradient(135deg,#ff7fb6,#ffd9eb);

    display:flex;

    justify-content:center;

    align-items:center;

    opacity:0;

    visibility:hidden;

    transition:.8s;

    z-index:100;

}

#loveScreen.show{

    opacity:1;

    visibility:visible;

}

.loveContent{

    text-align:center;

    color:white;

    animation:zoom 1s;

    padding:30px;

}

.loveContent h1{

    color:white;

    font-size:58px;

}

.loveContent h2{

    color:white;

    font-size:36px;

}

.loveContent p{

    margin-top:20px;

    line-height:2;

    font-size:24px;

}

@keyframes bgMove{

0%{background-position:0% 50%;}

50%{background-position:100% 50%;}

100%{background-position:0% 50%;}

}

@keyframes floating{

50%{

transform:translateY(-12px);

}

}

@keyframes glow{

50%{

box-shadow:
0 0 35px hotpink,
0 0 70px #ff8fc4,
0 0 100px #ffc5df;

}

}

@keyframes fadeUp{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}

@keyframes zoom{

from{

transform:scale(.7);

opacity:0;

}

to{

transform:scale(1);

opacity:1;

}

}

@keyframes fall{

from{

transform:translateY(-10vh) rotate(0deg);

}

to{

transform:translateY(110vh) rotate(360deg);

}

}